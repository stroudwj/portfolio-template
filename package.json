{
  "name": "portfoliosite",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "runtime:generate": "node scripts/generate-runtime-release.mjs",
    "runtime:check": "node scripts/generate-runtime-release.mjs --check",
    "runtime:hydration": "node scripts/build-hydration-runtime.mjs",
    "prebuild": "npm run runtime:check && npm run runtime:hydration",
    "prebuild:product": "npm run runtime:check && npm run runtime:hydration",
    "dev": "astro dev",
    "build": "astro build",
    "build:product": "astro build --config astro.config.product.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "astro": "^6.3.7",
    "fflate": "^0.8.3",
    "idb-keyval": "^6.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
