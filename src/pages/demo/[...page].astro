---
// The live demo of the portfolio template, product site only (buyer repos emit no
// /demo pages). Same components as the real portfolio, but every link is rebased
// under /demo so visitors stay inside the demo, and the pages are noindex — the demo
// duplicates the template's placeholder content and shouldn't compete with the landing.
import Layout from '../../layouts/Layout.astro';
import PortfolioPage from '../../portfolio/PortfolioPage';
import { content, pageTitle } from '../../lib/content';
import { resolvePageGalleries, resolveProfileImage, resolveChildThumbs } from '../../lib/resolveImages';
import { IS_PRODUCT_SITE } from '../../lib/productSite';
import { currentPriceText, pricing, regularPriceText } from '../../lib/pricing';
import { withBase } from '../../portfolio/types';

export function getStaticPaths() {
	if (!IS_PRODUCT_SITE) return [];
	return Object.keys(content.pages).map((key) => ({ params: { page: key === 'home' ? undefined : key } }));
}

const pageKey = Astro.params.page || 'home';
const page = content.pages[pageKey];
const galleries = await resolvePageGalleries(pageKey);
const hasImages = Object.keys(galleries).length > 0;
const hasInteractiveBlocks = !!page.mobile || page.blocks?.some((block) => block.type === 'form');
const hasAbout = page.blocks?.some((b) => b.type === 'about');
const profile = hasAbout ? await resolveProfileImage() : {};
const pageThumbs = await resolveChildThumbs(pageKey);

const siteBase = import.meta.env.BASE_URL;
const base = withBase(siteBase, 'demo');
---

<Layout title={`Demo — ${pageTitle(page.title)}`} showLogo={true} base={base} noindex={true}>
	<a slot="banner" class="demo-banner" href={withBase(siteBase)}>
		This is a demo — hang your own for{' '}
		{pricing.launchPricingActive && <del>{regularPriceText}</del>}
		<strong>{currentPriceText}, once</strong>
	</a>
	{
		hasImages || hasInteractiveBlocks ? (
			<PortfolioPage
				client:load
				page={pageKey}
				content={content}
				galleries={galleries}
				profileImageSrc={profile.src}
				pageThumbs={pageThumbs}
				base={base}
			/>
		) : (
			<PortfolioPage
				page={pageKey}
				content={content}
				galleries={{}}
				profileImageSrc={profile.src}
				pageThumbs={pageThumbs}
				base={base}
			/>
		)
	}
</Layout>

<style>
	.demo-banner {
		position: fixed;
		bottom: 1rem;
		right: 1rem;
		z-index: 100;
		background: #faf8f5;
		color: #1a1a1a;
		border: 1px solid #ddd9d0;
		text-decoration: none;
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		font-size: 14px;
		font-weight: 400;
		padding: 0.6rem 1rem;
		border-radius: 4px;
	}
	.demo-banner strong {
		font-weight: 500;
	}
	.demo-banner del {
		margin-right: 0.35rem;
		color: #6b6963;
		text-decoration-thickness: 1px;
	}
	.demo-banner:hover strong {
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}
	.demo-banner:focus-visible {
		outline: 2px solid #002fa7;
		outline-offset: 2px;
	}
</style>
