---
import Layout from '../layouts/Layout.astro';
import PortfolioPage from '../portfolio/PortfolioPage';
import { content, pageTitle } from '../lib/content';
import { resolveProfileImage } from '../lib/resolveImages';

// The About page is static (no interactivity), so it renders without hydration.
const page = content.pages.bio;
const profile = await resolveProfileImage();
const base = import.meta.env.BASE_URL;
---

<Layout title={pageTitle(page.title)} showLogo={true}>
	<PortfolioPage page="bio" content={content} galleries={{}} profileImageSrc={profile.src} base={base} />
</Layout>
