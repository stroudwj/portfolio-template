---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Your Name" showLogo={true}>
  <div class="bio-container">
    <p class="bio-text">
Your Name<br />
<br />
<br />
Born in Somewhere.<br />

Lives and works in Your City.<br />
<br />
Artist. Designer. Photographer.<br />
<br />
you@example.com
    </p>
  </div>
</Layout>

<style>
  .bio-container {
    padding: 25vh 0px 0px;
    margin-left: 25vw;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    width: 33.333%;
    min-width: 300px;
    font-weight: 500;

  }

  .bio-text {
    text-align: left;
    line-height: 1.6;
    text-wrap: pretty;
    margin: 0;
  }

  @media (max-width: 900px) {
    .bio-container {
      padding: 220px 30px 40px;
      margin-left: 0;
      width: 100%;
      max-width: 600px;
      min-width: 0;
    }
  }
</style>