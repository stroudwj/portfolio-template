---
// Every non-home portfolio page — top-level pages AND nested sub-pages (whose keys
// contain slashes, e.g. work/project-a) — driven by content.pages so the site adapts
// as pages are added, removed, or nested in the editor. Pages with a gallery hydrate
// for the hover/lightbox interactions; the rest render static. On the product site
// none of these emit — the portfolio renders under /demo instead.
import Layout from '../layouts/Layout.astro';
import PortfolioPage from '../portfolio/PortfolioPage';
import { content, pageTitle } from '../lib/content';
import { resolvePageGalleries, resolveProfileImage, resolveChildThumbs } from '../lib/resolveImages';
import { IS_PRODUCT_SITE } from '../lib/productSite';

export function getStaticPaths() {
	if (IS_PRODUCT_SITE) return [];
	return Object.keys(content.pages)
		.filter((key) => key !== 'home' && !content.pages[key].draft)
		.map((key) => ({ params: { page: key } }));
}

const pageKey = Astro.params.page!;
const page = content.pages[pageKey];
const galleries = await resolvePageGalleries(pageKey);
const hasImages = Object.keys(galleries).length > 0;
const hasInteractiveBlocks = !!page.mobile || page.blocks?.some((block) => block.type === 'form');
const hasAbout = page.blocks?.some((b) => b.type === 'about');
const profile = hasAbout ? await resolveProfileImage() : {};
const pageThumbs = await resolveChildThumbs(pageKey);
const base = import.meta.env.BASE_URL;
---

<Layout title={pageTitle(page.title)} description={page.description} showLogo={true} noindex={page.noindex}>
	{
		hasImages || hasInteractiveBlocks ? (
			<PortfolioPage
				client:load
				page={pageKey}
				content={content}
				galleries={galleries}
				profileImageSrc={profile.src}
				pageThumbs={pageThumbs}
				base={base}
			/>
		) : (
			<PortfolioPage
				page={pageKey}
				content={content}
				galleries={{}}
				profileImageSrc={profile.src}
				pageThumbs={pageThumbs}
				base={base}
			/>
		)
	}
</Layout>
