---
// The browser-based editor — the no-code builder people use to create and publish their
// site. It's deployed with the site (but noindex) so it works from any device; it's never
// part of a visitor-facing page. Rendered client-only (uploads, IndexedDB, OAuth redirect).
import EditorApp from '../editor/EditorApp';
import { withBase } from '../portfolio/types';
// The preview renders the portfolio components inside a client:only island, whose
// code-split CSS Astro can't discover without an SSR pass. Import the styles at the
// page level so they're linked in the production build. See preview.css for details.
import '../portfolio/preview.css';

const base = import.meta.env.BASE_URL;
const favicon = withBase(base, 'favicon.svg');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<link rel="icon" type="image/svg+xml" href={favicon} />
		<title>Portfolio Editor</title>
	</head>
	<body>
		<EditorApp client:only="react" base={base} />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		padding: 0;
		height: 100%;
	}
	* {
		box-sizing: border-box;
	}
</style>
