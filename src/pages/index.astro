---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import { content, pageTitle } from '../lib/content';
import { getGallery } from '../lib/galleries';

// All content for this page comes from src/data/content.json — to add images,
// drop files in the folder named there (src/assets/selected-works/ by default).
const page = content.pages.home;
const gallery = page.gallery!;
const items = getGallery(gallery.folder, gallery.order, content.galleries[gallery.folder]?.items);
---

<Layout title={pageTitle(page.title)} showLogo={true}>
  <div class="page-header">
    <h1 class="page-title">{page.heading}</h1>
  </div>

  <div class="collage-container">
    <Gallery items={items} alt={gallery.alt} />
  </div>
</Layout>

<style>
  .page-header {
    padding: 70px;
    margin-bottom: 0;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.02em;
    text-align: right;
  }

  .collage-container {
    padding: 20px 40px 60px;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 60px 20px;
    }
    .collage-container {
      padding: 80px 20px 40px;
    }
  }
</style>
