---
import Layout from '../layouts/Layout.astro';
import PortfolioPage from '../portfolio/PortfolioPage';
import { content, pageTitle } from '../lib/content';
import { resolveGallery } from '../lib/resolveImages';

// All content comes from src/data/content.json; images are read from the folder
// named there (src/assets/selected-works/ by default) and optimized here.
const page = content.pages.home;
const folder = page.gallery!.folder;
const galleries = { [folder]: await resolveGallery(folder) };
const base = import.meta.env.BASE_URL;
---

<Layout title={pageTitle(page.title)} showLogo={true}>
	<PortfolioPage client:visible page="home" content={content} galleries={galleries} base={base} />
</Layout>
