---
// Every non-home portfolio page, driven by content.nav (so the template adapts if a
// buyer's nav changes). Gallery pages hydrate for the hover/lightbox interactions;
// text-only pages (About) render static, exactly like the old per-page files did.
// On the product site none of these emit — the portfolio renders under /demo instead.
import Layout from '../layouts/Layout.astro';
import PortfolioPage from '../portfolio/PortfolioPage';
import { content, pageTitle } from '../lib/content';
import { resolveGallery, resolveProfileImage } from '../lib/resolveImages';
import { IS_PRODUCT_SITE } from '../lib/productSite';

export function getStaticPaths() {
	if (IS_PRODUCT_SITE) return [];
	return content.nav.filter((item) => item.path !== '').map((item) => ({ params: { page: item.path } }));
}

const pageKey = Astro.params.page!;
const page = content.pages[pageKey];
const gallery = page.gallery;
const galleries = gallery ? { [gallery.folder]: await resolveGallery(gallery.folder) } : {};
const profile = gallery ? {} : await resolveProfileImage();
const base = import.meta.env.BASE_URL;
---

<Layout title={pageTitle(page.title)} showLogo={true}>
	{
		gallery ? (
			<PortfolioPage client:visible page={pageKey} content={content} galleries={galleries} base={base} />
		) : (
			<PortfolioPage page={pageKey} content={content} galleries={{}} profileImageSrc={profile.src} base={base} />
		)
	}
</Layout>
