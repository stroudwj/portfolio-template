---
// Reusable image gallery: a responsive grid + click-to-zoom lightbox.
//
// Each page passes in its own list of images. You usually don't need to edit
// this file — to change what appears in a gallery, just add or remove image
// files in that page's assets folder.
import { Image } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
  alt?: string;
}

const { images, alt = 'Portfolio piece' } = Astro.props;
---

{images.length > 0 ? (
  <div class="masonry-grid">
    {images.map((img) => (
      <div class="masonry-item">
        <Image
          src={img}
          alt={alt}
          width={800}
          class="lightbox-trigger"
          data-full-src={img.src}
        />
      </div>
    ))}
  </div>
) : (
  <div class="gallery-empty">
    <p>No images yet. Add photos to this page's folder in <code>src/assets/</code> and they'll appear here automatically.</p>
  </div>
)}

<div id="image-modal" class="modal" role="dialog" aria-hidden="true">
  <span class="close-btn">&times;</span>
  <img id="modal-img" src="" alt="Full resolution portfolio piece" />
</div>

<style>
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
  }

  @media (min-width: 640px) {
    .masonry-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 1024px) {
    .masonry-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (min-width: 1536px) {
    .masonry-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  .masonry-item { width: 100%; }

  .masonry-item img {
    width: 100%;
    height: auto;
    display: block;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease;
    cursor: zoom-in;
  }

  .masonry-item img:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
  }

  .gallery-empty {
    padding: 3rem 0;
    color: #666;
    font-size: 1rem;
  }

  .gallery-empty code {
    background: #ececec;
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Lightbox modal */
  .modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .modal.show {
    display: flex;
    opacity: 1;
    pointer-events: auto;
  }

  .modal img {
    max-width: 90vw;
    max-height: 85vh;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    object-fit: contain;
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .modal.show img { transform: scale(1); }

  .close-btn {
    position: absolute;
    top: 25px;
    right: 35px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 44px;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s ease, transform 0.2s ease;
    z-index: 10000;
    user-select: none;
  }

  .close-btn:hover {
    color: #fff;
    transform: scale(1.1);
  }
</style>

<script>
  function setupLightbox() {
    const modal = document.getElementById('image-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement | null;
    const closeBtn = document.querySelector('.close-btn');
    const triggers = document.querySelectorAll('.lightbox-trigger');

    if (!modal || !modalImg || !closeBtn) return;

    const openModal = (src: string) => {
      modalImg.src = src;
      modal.classList.add('show');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      modal.classList.remove('show');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setTimeout(() => {
        if (!modal.classList.contains('show')) modalImg.src = '';
      }, 300);
    };

    triggers.forEach((img) => {
      img.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLImageElement;
        const fullSrc = target.getAttribute('data-full-src');
        if (fullSrc) openModal(fullSrc);
      });
    });

    closeBtn.addEventListener('click', closeModal);

    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('show')) closeModal();
    });
  }

  document.addEventListener('DOMContentLoaded', setupLightbox);
  document.addEventListener('astro:page-load', setupLightbox);
</script>
