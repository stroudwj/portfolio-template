---
import { withBase } from '../portfolio/types';

interface Props {
	base?: string;
	svg?: string;
}

const { base = import.meta.env.BASE_URL, svg = 'favicon.svg' } = Astro.props;
---

<link rel="icon" href={withBase(base, 'favicon.ico')} sizes="any" />
<link rel="icon" type="image/svg+xml" href={withBase(base, svg)} />
<link rel="icon" type="image/png" sizes="32x32" href={withBase(base, 'favicon-32.png')} />
<link rel="icon" type="image/png" sizes="16x16" href={withBase(base, 'favicon-16.png')} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase(base, 'apple-touch-icon.png')} />
