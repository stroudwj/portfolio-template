---
// The site's menu. To add, remove, or rename a page, edit the `nav` list in
// src/data/content.json — set `path` to the page's file name in src/pages/
// (use '' for the Home page, index.astro).
import { content } from '../lib/content';
const navItems = content.nav;

// Astro serves the site under this base path (set in astro.config.mjs). We build
// links from it and compare against the current URL so highlighting works whether
// the site lives at the root or in a subfolder (e.g. GitHub Pages).
const base = import.meta.env.BASE_URL;
const stripSlashes = (value: string) => value.replace(/^\/+|\/+$/g, '');
const withBase = (path = '') => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const currentPage = stripSlashes(Astro.url.pathname.replace(stripSlashes(base), ''));

const links = navItems.map((item) => ({
	label: item.label,
	href: withBase(item.path),
	isActive: stripSlashes(item.path) === currentPage,
}));
---

<div class="navigation-shell">
  <div class="mac-dock-vertical desktop-nav">
    {links.map((item) => (
      <a href={item.href} class={`dock-link ${item.isActive ? 'active' : ''}`}>
        <span class="dock-item">{item.label}</span>
      </a>
    ))}
  </div>

  <details class="mobile-nav">
    <summary class="mobile-nav-trigger" aria-label="Open site navigation">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </summary>
    <div class="mobile-nav-panel">
      {links.map((item) => (
        <a href={item.href} class={`mobile-nav-link ${item.isActive ? 'active' : ''}`}>
          {item.label}
        </a>
      ))}
    </div>
  </details>
</div>

<style>
.navigation-shell {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.mac-dock-vertical {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 5px 5px; /* top/bottom, left/right */
  background: transparent;
}

.mobile-nav {
  display: none;
  position: fixed;
  top: 16px;
  left: 16px;
  z-index: 2000;
  background: transparent;
  padding: 0;
  width: fit-content;
}

.mobile-nav[open] {
  background: var(--color-bg);
  padding: 6px 8px 8px;
}

.mobile-nav-trigger {
  list-style: none;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 6px 4px;
  background: transparent;
  border: 0;
}

.mobile-nav-trigger::-webkit-details-marker {
  display: none;
}

.hamburger-line {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-accent);
  border-radius: 999px;
}

.mobile-nav-panel {
  margin-top: 10px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 8px 4px 2px;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  min-width: 120px;
}

.mobile-nav-link {
  font-family: var(--font-family);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-text);
  text-decoration: none;
}

.mobile-nav-link.active {
  text-decoration: underline;
  text-underline-offset: 0.18em;
}

.dock-link {
  display: flex;
  align-items: center;      
  text-decoration: none;    
  background: transparent;
  margin: 0;
  padding-top: 3px;   
  padding-bottom: 3px;
  -webkit-tap-highlight-color: transparent; /* Remove default mobile tap highlight */
}

.dock-item {
  font-family: var(--font-family);
  font-size: 0.7rem;        
  font-weight: 700;         
  color: #333333;           
  letter-spacing: 0.3px;    
  white-space: nowrap;
  display: inline-block;
  transform-origin: left center; 
  position: relative;
}

/* Underline setup */
.dock-item::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -2px;
  width: 100%;
  height: 2px;
  background-color: var(--color-accent);
  transform: scaleX(0);
  transition: transform 0.2s ease;
  transform-origin: left center;
}

/* Active page gets underlined globally */
.dock-link.active .dock-item::after {
  transform: scaleX(1);
  background-color: var(--color-accent);
}
.dock-link.active .dock-item {
  color: var(--color-accent);
}

/* Desktop Styles (Devices with hover capability) */
@media (hover: hover) {
  .dock-link { transition: padding 0.28s cubic-bezier(0.25, 1, 0.5, 1); }
  .dock-item { transition: transform 0.28s cubic-bezier(0.25, 1, 0.5, 1), color 0.2s ease; will-change: transform; }
  /* Allow active underline on desktop */
  .dock-link.active .dock-item::after { transform: scaleX(1); }
}

/* Mobile / Touch Styles (Devices without hover capability) */
@media (hover: none) {
  .dock-link { 
    padding-top: 8px !important; 
    padding-bottom: 8px !important; 
  }
  
  /* Show underline when actively tapping/clicking a link */
  .dock-link:active .dock-item::after { 
    transform: scaleX(1); 
  }
  
  /* Ensure text color changes on tap */
  .dock-link:active .dock-item {
    color: var(--color-accent);
  }
  
  /* Active page stays underlined (overriding just in case) */
  .dock-link.active .dock-item::after { 
    transform: scaleX(1); 
  }
}

@media (max-width: 768px) {
  .desktop-nav {
    display: none;
  }

  .mobile-nav {
    display: block;
  }
}
</style>

<script>
// This client-side script runs perfectly on desktop windows
const container = document.querySelector('.mac-dock-vertical');
const links = document.querySelectorAll('.dock-link');
const isDesktop = window.matchMedia('(hover: hover)').matches;

if (isDesktop && container) {
  links.forEach((activeLink, index) => {
    activeLink.addEventListener('mouseenter', () => {
      links.forEach((link, idx) => {
        const item = link.querySelector('.dock-item') as HTMLElement;
        const currentLink = link as HTMLElement;
        if (!item) return;

        if (idx === index) {
          item.style.transform = 'scale(1.8)';
          item.style.color = '#000000';
          currentLink.style.paddingTop = '12px';
          currentLink.style.paddingBottom = '12px';
        } else if (Math.abs(idx - index) === 1) {
          item.style.transform = 'scale(1.25)';
          item.style.color = '#666666';
          currentLink.style.paddingTop = '6px';
          currentLink.style.paddingBottom = '6px';
        } else {
          item.style.transform = 'scale(1)';
          item.style.color = '#999999';
          currentLink.style.paddingTop = '3px';
          currentLink.style.paddingBottom = '3px';
        }
      });
    });
  });

  container.addEventListener('mouseleave', () => {
    links.forEach(link => {
      const item = link.querySelector('.dock-item') as HTMLElement;
      const currentLink = link as HTMLElement;
      if (item) {
        item.style.transform = 'scale(1)';
        item.style.color = '#333333';
      }
      if (currentLink) {
        currentLink.style.paddingTop = '3px';
        currentLink.style.paddingBottom = '3px';
      }
    });
  });
}
</script>