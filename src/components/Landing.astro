---
// The product site's sales page, rendered at the root ONLY when IS_PRODUCT_SITE is
// true (see src/pages/index.astro). It's a full standalone document on purpose:
// Layout.astro carries the portfolio's theme, og:image and description from
// content.json, none of which belong on a marketing page. No lemon.js here either —
// the checkout overlay is editor-only.
import { withBase } from '../portfolio/types';

const base = import.meta.env.BASE_URL;
const editorUrl = withBase(base, 'editor/');
const demoUrl = withBase(base, 'demo/');
const title = 'Hangwork — portfolio websites for visual artists';
const description =
	'A portfolio builder that stays out of the way of your art. Build in the browser, publish to a space you own. $19 once, no subscription.';
const canonicalUrl = Astro.site ? new URL(withBase(base), Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={withBase(base, 'favicon.svg')} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Hangwork" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
	</head>
	<body>
		<header class="topbar">
			<span class="brand">hangwork<span class="brand-dot">.</span></span>
			<nav class="topnav">
				<a href={demoUrl}>Demo</a>
				<a href="#faq">Questions</a>
			</nav>
		</header>

		<main>
			<section class="hero">
				<h1>A quiet wall for your work.</h1>
				<p class="lede">
					Hangwork is a portfolio builder for visual artists. The site it makes is deliberately
					plain — your work is the only loud thing on it. Arrange your pieces in the browser,
					then publish to a space you own.
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href={editorUrl}>Hang your first piece</a>
					<a class="btn btn-secondary" href={demoUrl}>See the demo</a>
				</div>
				<p class="hero-note">Free to build and preview. $19 when you publish — once.</p>
			</section>

			<section class="ownership">
				<h2>Yours, not ours</h2>
				<p>
					Your portfolio lives in an account you own — not ours. One payment. No subscription.
					No hostage fees. If Hangwork vanished tomorrow, your site would keep standing.
				</p>
			</section>

			<section class="faq" id="faq">
				<h2>Questions</h2>
				<dl>
					<dt>Do I need to know how to code?</dt>
					<dd>No. You arrange your pages in the editor and publish with one button.</dd>
					<dt>What does it cost?</dt>
					<dd>
						$19, once. Building and previewing are free — you pay when you're ready to publish.
						Nothing renews.
					</dd>
					<dt>Where does my site live?</dt>
					<dd>
						In a free account where your site is stored (GitHub), claimed under your name. The
						editor walks you through claiming your space, and that account is what makes the
						site yours — hosting included, at no cost.
					</dd>
					<dt>Can I use my own domain?</dt>
					<dd>
						Yes. Add it in the editor and we'll show you the exact records to set with your
						registrar.
					</dd>
					<dt>Can I change my site later?</dt>
					<dd>
						Rehang anytime. Open the editor from any device, sign in, and your wall comes back
						ready to edit.
					</dd>
					<dt>What about refunds?</dt>
					<dd>
						Payments are handled by Lemon Squeezy. If something isn't working for you, email
						<a href="mailto:william.stroud100@gmail.com">william.stroud100@gmail.com</a> and
						we'll make it right.
					</dd>
				</dl>
			</section>
		</main>

		<footer class="footer">
			<span class="brand">hangwork<span class="brand-dot">.</span></span>
			<nav>
				<a href={demoUrl}>Demo</a>
				<a href={editorUrl}>Editor</a>
				<a href="mailto:william.stroud100@gmail.com">Support</a>
			</nav>
			<span class="footer-note">Payments and refunds are handled by Lemon Squeezy.</span>
		</footer>
	</body>
</html>

<style>
	:root {
		--paper: #faf8f5;
		--ink: #1a1a1a;
		--ink-soft: #6b6963;
		--klein: #002fa7;
		--klein-dark: #00248a;
		--wall-1: #edeae4;
		--wall-2: #ddd9d0;
		--wall-3: #e5e1da;
		--error: #b3261e;
	}
	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--paper);
		color: var(--ink);
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
			sans-serif;
		font-size: 16px;
		font-weight: 400;
		line-height: 1.6;
	}
	* {
		box-sizing: border-box;
	}
	main {
		display: block;
	}
	:is(a, button):focus-visible {
		outline: 2px solid var(--klein);
		outline-offset: 2px;
	}

	.brand {
		font-weight: 500;
		color: var(--ink);
		letter-spacing: -0.01em;
	}
	.brand-dot {
		color: var(--klein);
	}

	.topbar {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 28px 32px;
	}
	.topnav {
		display: flex;
		align-items: baseline;
		gap: 28px;
	}
	.topnav a {
		color: var(--ink-soft);
		text-decoration: none;
		font-size: 15px;
	}
	.topnav a:hover {
		color: var(--ink);
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	.btn {
		display: inline-block;
		border-radius: 4px;
		padding: 10px 22px;
		font-size: 15px;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid transparent;
	}
	.btn-primary {
		background: var(--klein);
		color: var(--paper);
	}
	.btn-primary:hover {
		background: var(--klein-dark);
	}
	.btn-secondary {
		background: transparent;
		border-color: var(--wall-2);
		color: var(--ink);
	}
	.btn-secondary:hover {
		background: var(--wall-3);
	}

	.hero,
	.ownership,
	.faq {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 32px;
	}

	.hero {
		padding-top: 96px;
	}
	.hero h1 {
		font-size: clamp(32px, 5.5vw, 54px);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: -0.02em;
		margin: 0 0 24px;
		max-width: 14em;
	}
	.lede {
		font-size: 16px;
		color: var(--ink-soft);
		margin: 0 0 40px;
		max-width: 34em;
	}
	.cta-row {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}
	.hero-note {
		margin-top: 20px;
		font-size: 14px;
		color: var(--ink-soft);
	}

	h2 {
		font-size: 26px;
		font-weight: 500;
		letter-spacing: -0.01em;
		line-height: 1.3;
		margin: 0 0 20px;
	}

	.ownership {
		margin-top: 128px;
	}
	.ownership p {
		margin: 0;
		max-width: 34em;
	}

	.faq {
		margin-top: 128px;
		padding-bottom: 128px;
	}
	.faq dl {
		margin: 0;
		max-width: 38em;
	}
	.faq dt {
		font-weight: 500;
		margin-top: 32px;
	}
	.faq dd {
		margin: 6px 0 0;
		color: var(--ink-soft);
	}
	.faq a {
		color: var(--ink);
		text-decoration: none;
	}
	.faq a:hover {
		color: var(--klein);
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	.footer {
		border-top: 1px solid var(--wall-2);
		padding: 40px 32px 48px;
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 12px;
		font-size: 14px;
		color: var(--ink-soft);
	}
	.footer nav {
		display: flex;
		gap: 24px;
	}
	.footer a {
		color: var(--ink-soft);
		text-decoration: none;
	}
	.footer a:hover {
		color: var(--ink);
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}
	.footer-note {
		font-size: 13px;
	}

	@media (max-width: 640px) {
		.topbar {
			padding: 20px;
		}
		.hero,
		.ownership,
		.faq {
			padding-left: 20px;
			padding-right: 20px;
		}
		.hero {
			padding-top: 64px;
		}
		.ownership,
		.faq {
			margin-top: 96px;
		}
		.faq {
			padding-bottom: 96px;
		}
		.footer {
			padding: 32px 20px 40px;
		}
	}
</style>
