---
// The product site's sales page, rendered at the root ONLY when IS_PRODUCT_SITE is
// true (see src/pages/index.astro). It's a full standalone document on purpose:
// Layout.astro carries the portfolio's theme, og:image and description from
// content.json, none of which belong on a marketing page. No lemon.js here either —
// the checkout overlay is editor-only.
import { withBase } from '../portfolio/types';

const base = import.meta.env.BASE_URL;
const editorUrl = withBase(base, 'editor/');
const demoUrl = withBase(base, 'demo/');
const title = 'Hangwork — portfolio websites for visual artists';
const description =
	'A portfolio site for visual artists. One payment, no subscription, no platform holding your work hostage.';
const canonicalUrl = Astro.site ? new URL(withBase(base), Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={withBase(base, 'favicon.svg')} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Hangwork" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
	</head>
	<body>
		<header class="topbar">
			<a class="brand" href={withBase(base)}>hangwork<span class="brand-accent">.art</span></a>
			<nav class="topnav">
				<a href="#how">How it works</a>
				<a href="#examples">Examples</a>
				<a href="#pricing">Pricing</a>
			</nav>
		</header>

		<main>
			<section class="hero">
				<h1>Hang your work.<br />Own it forever.</h1>
				<p class="lede">
					A portfolio site for visual artists. One payment, no subscription, no platform holding
					your work hostage.
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href={editorUrl}>Hang your first piece</a>
					<a class="btn btn-secondary" href={demoUrl}>See an example wall</a>
				</div>
			</section>

			<section class="band" id="how">
				<h2>How it works</h2>
				<ol class="steps">
					<li>
						<span class="step-num">01</span>
						<p>Build your wall in the browser. Add your pieces, arrange them, watch the preview.</p>
					</li>
					<li>
						<span class="step-num">02</span>
						<p>Claim your space — a free account where your site is stored, in your name.</p>
					</li>
					<li>
						<span class="step-num">03</span>
						<p>Publish. Your site goes live at its own address. Come back anytime to rehang.</p>
					</li>
				</ol>
			</section>

			<section class="band" id="examples">
				<h2>Examples</h2>
				<p class="band-lede">See a full site built with Hangwork — the same quiet wall your work will hang on.</p>
				<a class="btn btn-secondary" href={demoUrl}>See an example wall</a>
			</section>

			<section class="band" id="pricing">
				<h2>Pricing</h2>
				<p class="price">$19, once.</p>
				<p class="band-lede">
					One payment. No subscription. Building and previewing are free — you pay when you're
					ready to publish, and your site is yours to keep.
				</p>
				<a class="btn btn-primary" href={editorUrl}>Hang your first piece</a>
			</section>
		</main>

		<footer class="footer">
			<a class="brand" href={withBase(base)}>hangwork<span class="brand-accent">.art</span></a>
			<nav>
				<a href={demoUrl}>Examples</a>
				<a href={editorUrl}>Editor</a>
				<a href="mailto:william.stroud100@gmail.com">Support</a>
			</nav>
			<span class="footer-note">Payments and refunds are handled by Lemon Squeezy.</span>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--paper: #faf8f5;
		--ink: #1a1a1a;
		--ink-soft: #6b6963;
		--klein: #002fa7;
		--klein-dark: #00248a;
		--wall-2: #ddd9d0;
		--wall-3: #e5e1da;
	}
	* {
		box-sizing: border-box;
	}
	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--paper);
		color: var(--ink);
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
			sans-serif;
		font-size: 16px;
		font-weight: 400;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}
	:is(a, button):focus-visible {
		outline: 2px solid var(--klein);
		outline-offset: 3px;
	}

	.brand {
		font-size: 16px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--ink);
		text-decoration: none;
	}
	.brand-accent {
		color: var(--klein);
	}

	.topbar {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 28px 32px;
	}
	.topnav {
		display: flex;
		align-items: baseline;
		gap: 28px;
	}
	.topnav a {
		color: var(--ink-soft);
		text-decoration: none;
		font-size: 15px;
		white-space: nowrap;
	}
	.topnav a:hover {
		color: var(--ink);
	}

	.btn {
		display: inline-block;
		border-radius: 4px;
		padding: 11px 22px;
		font-size: 15px;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid transparent;
	}
	.btn-primary {
		background: var(--klein);
		color: var(--paper);
	}
	.btn-primary:hover {
		background: var(--klein-dark);
	}
	.btn-secondary {
		background: transparent;
		border-color: var(--wall-2);
		color: var(--ink);
	}
	.btn-secondary:hover {
		background: var(--wall-3);
	}

	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 32px;
	}

	.hero {
		min-height: 68vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 48px 0 24px;
	}
	.hero h1 {
		font-size: clamp(34px, 6vw, 56px);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: -0.02em;
		margin: 0 0 24px;
	}
	.lede {
		font-size: 17px;
		color: var(--ink-soft);
		margin: 0 0 36px;
		max-width: 30em;
	}
	.cta-row {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.band {
		padding: 112px 0;
		border-top: 1px solid var(--wall-2);
	}
	.band h2 {
		font-size: 15px;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--ink-soft);
		margin: 0 0 32px;
	}
	.band-lede {
		font-size: 17px;
		color: var(--ink);
		margin: 0 0 32px;
		max-width: 34em;
	}

	.steps {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
	}
	.steps li {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}
	.step-num {
		font-size: 14px;
		color: var(--ink-soft);
		font-variant-numeric: tabular-nums;
	}
	.steps p {
		margin: 0;
		font-size: 16px;
		max-width: 20em;
	}

	.price {
		font-size: clamp(30px, 4vw, 40px);
		font-weight: 500;
		letter-spacing: -0.02em;
		margin: 0 0 20px;
	}

	.footer {
		max-width: 1100px;
		margin: 0 auto;
		border-top: 1px solid var(--wall-2);
		padding: 40px 32px 56px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 14px;
		font-size: 14px;
		color: var(--ink-soft);
	}
	.footer nav {
		display: flex;
		gap: 24px;
	}
	.footer a {
		color: var(--ink-soft);
		text-decoration: none;
	}
	.footer a:hover {
		color: var(--ink);
	}
	.footer .brand {
		color: var(--ink);
	}
	.footer-note {
		font-size: 13px;
	}

	@media (max-width: 700px) {
		.topbar {
			padding: 20px;
		}
		.topnav {
			gap: 20px;
		}
		main {
			padding: 0 20px;
		}
		.hero {
			min-height: 0;
			padding: 56px 0 32px;
		}
		.band {
			padding: 80px 0;
		}
		.steps {
			grid-template-columns: 1fr;
			gap: 28px;
		}
		.footer {
			padding: 32px 20px 44px;
		}
	}

	/* Below ~460px the brand + nav can't share a line — stack them. */
	@media (max-width: 460px) {
		.topbar {
			flex-direction: column;
			align-items: flex-start;
			gap: 14px;
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		html {
			scroll-behavior: smooth;
		}
	}
</style>
