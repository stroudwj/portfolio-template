---
// The product site's sales page, rendered at the root ONLY when IS_PRODUCT_SITE is
// true (see src/pages/index.astro). It's a full standalone document on purpose:
// Layout.astro carries the portfolio's theme, og:image and description from
// content.json, none of which belong on a marketing page. No lemon.js here either —
// the checkout overlay is editor-only.
import { withBase } from '../portfolio/types';
import { currentPrice, currentPriceText, pricing, regularPriceText } from '../lib/pricing';
import Favicons from './Favicons.astro';

const base = import.meta.env.BASE_URL;
const editorUrl = withBase(base, 'editor/');
const examplesUrl = withBase(base, 'examples');
const faqUrl = withBase(base, 'faq');
const guideUrl = withBase(base, 'guide');
const squarespaceAlternativeUrl = withBase(base, 'learn/squarespace-alternative-for-artists');
const noSubscriptionUrl = withBase(base, 'learn/portfolio-website-without-subscription');
const artPortfolioGuideUrl = withBase(base, 'learn/how-to-make-an-art-portfolio-site');
const brandLockup = withBase(base, 'assets/brand/hangwork-lockup.svg');
const title = 'Portfolio website builder for artists — Hangwork';
const description =
	'Build an art portfolio website with a visual editor. One payment, no subscription, an included hangwork.art address, and site files you own.';
const canonicalUrl = Astro.site ? new URL(withBase(base), Astro.site).href : undefined;
const applicationLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Hangwork',
	applicationCategory: 'DesignApplication',
	operatingSystem: 'Web browser',
	description,
	offers: {
		'@type': 'Offer',
		price: currentPrice,
		priceCurrency: 'USD',
		url: canonicalUrl,
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<Favicons base={base} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Hangwork" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(applicationLd)} is:inline />
	</head>
	<body>
		<header class="topbar">
			<a class="brand" href={withBase(base)} aria-label="Hangwork home">
				<img class="brand-logo" src={brandLockup} alt="Hangwork" />
			</a>
			<nav class="topnav">
				<a href="#how">How it works</a>
				<a href={examplesUrl}>Examples</a>
				<a href="#pricing">Pricing</a>
			</nav>
		</header>

		<main>
			<section class="hero">
				<!-- "Own it forever" links to its proof — what happens if Hangwork shuts down. -->
				<h1>
					Hang your work.<br /><a
						class="own-link"
						href={`${faqUrl}#if-hangwork-shuts-down`}
						title="What happens if Hangwork shuts down">Own it forever.</a
					>
				</h1>
				<p class="lede">
					A portfolio site for visual artists. One payment, no subscription, no platform holding
					your work hostage.
				</p>
				<div class="hero-actions">
					<div class="primary-action">
						<a class="btn btn-primary" href={editorUrl}>Hang your first piece</a>
						<p class="hero-price">
							{pricing.launchPricingActive && <del>{regularPriceText}</del>}
							<span class="hero-current-price">{currentPriceText}</span>
							<span>once. No subscription.</span>
						</p>
					</div>
					<a class="btn btn-secondary" href={examplesUrl}>View example sites</a>
				</div>
			</section>

			<section class="band" id="how">
				<h2>How it works</h2>
				<ol class="steps">
					<li>
						<span class="step-num">01</span>
						<p>Build your wall in the browser. Add your pieces, arrange them, watch the preview.</p>
					</li>
					<li>
						<span class="step-num">02</span>
						<p>Claim your space — a free account where your site is stored, in your name.</p>
					</li>
					<li>
						<span class="step-num">03</span>
						<p>Publish. Your site goes live at its own address. Come back anytime to rehang.</p>
					</li>
				</ol>
			</section>

			<section class="band" id="examples">
				<h2>Examples</h2>
				<p class="band-lede">See published portfolio sites built with Hangwork — each one shaped around the artist's own work.</p>
				<a class="btn btn-secondary" href={examplesUrl}>Browse example sites</a>
			</section>

			<section class="band" id="guides">
				<h2>Guides for artists</h2>
				<div class="guide-links">
					<a href={squarespaceAlternativeUrl}>
						<strong>A Squarespace alternative for artists</strong>
						<span>Compare the cost model, ownership, portfolio tools, and tradeoffs.</span>
					</a>
					<a href={noSubscriptionUrl}>
						<strong>Portfolio website without a subscription</strong>
						<span>See what one-time pricing includes and which optional costs remain.</span>
					</a>
					<a href={artPortfolioGuideUrl}>
						<strong>How to make an art portfolio site</strong>
						<span>Choose the work, prepare images, structure pages, write, test, and publish.</span>
					</a>
				</div>
			</section>

			<section class="band pricing" id="pricing">
				<div class="pricing-copy">
					<h2>One price</h2>
					<p class="price-lockup">
						{pricing.launchPricingActive && <del>{regularPriceText}</del>}
						<strong>{currentPriceText}</strong>
						<span>once</span>
					</p>
					{
						pricing.launchPricingActive && (
							<p class="launch-note">
								Launch price for early artists. Goes to {regularPriceText} when the first hundred walls are
								hung.
							</p>
						)
					}
					<p class="pricing-comparison">
						Squarespace and Wix use ongoing website plans. Hangwork: <strong>{currentPriceText}, once.</strong>
						<a href={squarespaceAlternativeUrl}> Compare the tradeoffs.</a>
					</p>
					<p class="included">
						Includes the editor, your yourname.hangwork.art address, publishing, and every future update to
						the editor.
					</p>
					<p class="ownership-note">
						<a href={`${faqUrl}#if-hangwork-shuts-down`}>
							Your site lives in an account you own — here's what that means.
						</a>
					</p>
					<a class="btn btn-primary" href={editorUrl}>Hang your first piece</a>
				</div>
			</section>
		</main>

		<footer class="footer">
			<a class="brand" href={withBase(base)} aria-label="Hangwork home">
				<img class="brand-logo" src={brandLockup} alt="Hangwork" />
			</a>
			<nav>
				<a href={examplesUrl}>Examples</a>
				<a href={artPortfolioGuideUrl}>Portfolio guide</a>
				<a href={guideUrl}>Setup guide</a>
				<a href={faqUrl}>Questions</a>
				<a href={editorUrl}>Editor</a>
				<a href="mailto:william.stroud100@gmail.com">Support</a>
			</nav>
			<span class="footer-note">Payments and refunds are handled by Lemon Squeezy.</span>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--paper: #faf8f5;
		--ink: #1a1a1a;
		--ink-soft: #6b6963;
		--klein: #002fa7;
		--klein-dark: #00248a;
		--wall-2: #ddd9d0;
		--wall-3: #e5e1da;
	}
	* {
		box-sizing: border-box;
	}
	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--paper);
		color: var(--ink);
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial,
			sans-serif;
		font-size: 16px;
		font-weight: 400;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}
	:is(a, button):focus-visible {
		outline: 2px solid var(--klein);
		outline-offset: 3px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
	}
	.brand-logo {
		display: block;
		width: auto;
		height: 50px;
	}

	.topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 28px 32px;
	}
	.topnav {
		display: flex;
		align-items: baseline;
		gap: 28px;
	}
	.topnav a {
		color: var(--ink-soft);
		text-decoration: none;
		font-size: 15px;
		white-space: nowrap;
	}
	.topnav a:hover {
		color: var(--ink);
	}

	.btn {
		display: inline-block;
		border-radius: 4px;
		padding: 11px 22px;
		font-size: 15px;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid transparent;
	}
	.btn-primary {
		background: var(--klein);
		color: var(--paper);
	}
	.btn-primary:hover {
		background: var(--klein-dark);
	}
	.btn-secondary {
		background: transparent;
		border-color: var(--wall-2);
		color: var(--ink);
	}
	.btn-secondary:hover {
		background: var(--wall-3);
	}

	main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 32px;
	}

	.hero {
		min-height: 68vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 48px 0 24px;
	}
	.hero h1 {
		font-size: clamp(34px, 6vw, 56px);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: -0.02em;
		margin: 0 0 24px;
	}
	/* Stays part of the headline — ink, not Klein — but underlines on hover/focus to
	   signal it leads to the proof (the FAQ's "if Hangwork shuts down" answer). */
	.own-link {
		color: inherit;
		text-decoration: none;
	}
	.own-link:hover,
	.own-link:focus-visible {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 6px;
	}
	.lede {
		font-size: 17px;
		color: var(--ink-soft);
		margin: 0 0 36px;
		max-width: 30em;
	}
	.hero-actions {
		display: flex;
		align-items: flex-start;
		gap: 16px;
		flex-wrap: wrap;
	}
	.primary-action {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 10px;
	}
	.hero-price {
		display: flex;
		align-items: baseline;
		gap: 5px;
		margin: 0;
		font-size: 13px;
		color: var(--ink-soft);
	}
	.hero-price del {
		color: var(--ink-soft);
		text-decoration-thickness: 1px;
	}
	.hero-current-price {
		color: var(--ink);
	}

	.band {
		padding: 112px 0;
		border-top: 1px solid var(--wall-2);
	}
	.band h2 {
		font-size: 15px;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--ink-soft);
		margin: 0 0 32px;
	}
	.band-lede {
		font-size: 17px;
		color: var(--ink);
		margin: 0 0 32px;
		max-width: 34em;
	}
	.guide-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}
	.guide-links a {
		display: flex;
		flex-direction: column;
		gap: 10px;
		min-height: 150px;
		padding: 22px;
		border: 1px solid var(--wall-2);
		border-radius: 4px;
		color: var(--ink);
		text-decoration: none;
	}
	.guide-links a:hover {
		background: var(--wall-3);
	}
	.guide-links strong {
		font-weight: 500;
		line-height: 1.4;
	}
	.guide-links span {
		color: var(--ink-soft);
		font-size: 13px;
		line-height: 1.55;
	}

	.steps {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 40px;
	}
	.steps li {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}
	.step-num {
		font-size: 14px;
		color: var(--ink-soft);
		font-variant-numeric: tabular-nums;
	}
	.steps p {
		margin: 0;
		font-size: 16px;
		max-width: 20em;
	}

	.pricing-copy {
		max-width: 46rem;
	}
	.price-lockup {
		display: flex;
		align-items: baseline;
		gap: 12px;
		margin: 0 0 20px;
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}
	.price-lockup del {
		font-size: clamp(28px, 4vw, 38px);
		font-weight: 400;
		color: var(--ink-soft);
		text-decoration-thickness: 1px;
	}
	.price-lockup strong {
		font-size: clamp(48px, 7vw, 56px);
		font-weight: 500;
		letter-spacing: -0.02em;
	}
	.price-lockup span {
		font-size: 16px;
	}
	.launch-note,
	.pricing-comparison,
	.included {
		max-width: 42rem;
		margin: 0 0 24px;
		font-size: 16px;
	}
	.launch-note {
		color: var(--ink-soft);
	}
	.pricing-comparison {
		padding: 18px 0;
		border-top: 1px solid var(--wall-2);
		border-bottom: 1px solid var(--wall-2);
	}
	.pricing-comparison strong {
		font-weight: 500;
	}
	.pricing-comparison a {
		color: var(--ink-soft);
		text-underline-offset: 3px;
	}
	.pricing-comparison a:hover {
		color: var(--ink);
	}
	.ownership-note {
		margin: 0 0 32px;
		font-size: 13px;
	}
	.ownership-note a {
		color: var(--ink-soft);
		text-decoration: none;
		text-underline-offset: 3px;
	}
	.ownership-note a:hover {
		color: var(--ink);
		text-decoration: underline;
		text-decoration-color: var(--wall-2);
	}

	.footer {
		max-width: 1100px;
		margin: 0 auto;
		border-top: 1px solid var(--wall-2);
		padding: 40px 32px 56px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 14px;
		font-size: 14px;
		color: var(--ink-soft);
	}
	.footer nav {
		display: flex;
		gap: 24px;
	}
	.footer a {
		color: var(--ink-soft);
		text-decoration: none;
	}
	.footer a:hover {
		color: var(--ink);
	}
	.footer .brand {
		margin-bottom: 2px;
	}
	.footer .brand-logo {
		height: 40px;
	}
	.footer-note {
		font-size: 13px;
	}

	@media (max-width: 700px) {
		.topbar {
			padding: 20px;
		}
		.topnav {
			gap: 20px;
		}
		main {
			padding: 0 20px;
		}
		.hero {
			min-height: 0;
			padding: 64px 0 40px;
		}
		.band {
			padding: 80px 0;
		}
		.steps {
			grid-template-columns: 1fr;
			gap: 28px;
		}
		.guide-links {
			grid-template-columns: 1fr;
		}
		.footer {
			padding: 32px 20px 44px;
		}
	}

	/* Below ~460px the brand + nav can't share a line — stack them. */
	@media (max-width: 460px) {
		.topbar {
			flex-direction: column;
			align-items: flex-start;
			gap: 14px;
		}
		.brand-logo {
			height: 44px;
		}
		.price-lockup {
			gap: 9px;
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		html {
			scroll-behavior: smooth;
		}
	}
</style>
