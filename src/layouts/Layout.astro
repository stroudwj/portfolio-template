---
// The root HTML shell. Chrome (logo + sidebar nav) and page bodies are rendered
// from the shared portfolio component system in src/portfolio/, so the site and
// the editor preview always render the exact same components.
import { content } from '../lib/content';
import { resolveOgImage, resolveLogoImage } from '../lib/resolveImages';
import { getFontUrl } from '../lib/galleries';
import { themeToRootCss, fontFacesCss, backgroundBlockVars } from '../portfolio/theme';
import Logo from '../portfolio/Logo';
import Nav from '../portfolio/Nav';
import CreativeEffects from '../portfolio/CreativeEffects';
import Favicons from '../components/Favicons.astro';
import { withBase, stripSlashes } from '../portfolio/types';
import '../portfolio/frame.css';

interface Props {
	title: string;
	/** Per-page meta description; falls back to site.description. */
	description?: string;
	showLogo?: boolean;
	/** Link prefix for nav/logo/favicon — override so /demo pages link within /demo. */
	base?: string;
	noindex?: boolean;
}

const { title, showLogo = false, base = import.meta.env.BASE_URL, noindex = false } = Astro.props;
const description = Astro.props.description || content.site.description;
const { site, theme, nav } = content;
const logo = site.logo || site.name;
const logoImageSrc = await resolveLogoImage();
const current = stripSlashes(Astro.url.pathname.replace(stripSlashes(base), ''));
// Site-wide nav layout + the current page's color-blocking background (if any).
const navStyle = theme.navStyle ?? 'dock';
const pageConfig = content.pages[current || 'home'];
const automaticContrast = theme.automaticTextContrast !== false;
const stabilized = theme.stabilizeNavigation !== false;
const pageBackground = pageConfig?.background || theme.backgroundColor;
const pageBgStyle = Object.entries(backgroundBlockVars(pageConfig?.background, automaticContrast))
	.map(([prop, value]) => `${prop}:${value}`)
	.join(';');
// Uploaded fonts become @font-face rules ahead of the theme variables that use them.
const fontFaces = (theme.customFonts ?? []).flatMap((font) => {
	const url = getFontUrl(font.file);
	return url ? [{ name: font.name, url }] : [];
});
// The html/body theming lives in THIS rendered string — not a `<style is:global>`
// block — because Astro bundles static styles from every imported component into the
// page. index.astro imports Layout even on the product site, where Layout never
// renders and the theme variables are never defined, so a static html/body rule with
// var(--color-bg)/var(--font-family) would land on the sales page and reset its
// background and font to browser defaults. Rendered styles only exist when Layout does.
const bodyCss = 'html,body{margin:0;padding:0;width:100%;height:100%;background-color:var(--color-bg);font-family:var(--font-family);}';
const themeCss = fontFacesCss(fontFaces) + themeToRootCss(theme) + bodyCss;

// Social cards need an ABSOLUTE image URL (getImage's src is base-prefixed but
// site-relative), and og:image can't be the favicon SVG — most platforms won't
// render an SVG card, so with no usable image we omit the tags entirely.
const ogImage = await resolveOgImage();
const ogImageUrl = ogImage && Astro.site ? new URL(ogImage, Astro.site).href : undefined;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
---

<!doctype html>
<html lang={site.language || 'en'} style={pageBgStyle || undefined}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		{noindex && <meta name="robots" content="noindex" />}
		<Favicons base={base} svg={site.favicon} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		<meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		<style is:global set:html={themeCss}></style>
		<title>{title}</title>
	</head>
	<body
		class:list={{
			'creative-loose-hang': site.creative?.looseHang,
			'creative-slow-reveal': site.creative?.slowReveal,
			'creative-artwork-wobble': site.creative?.artworkWobble,
			'creative-color-spin': site.creative?.colorSpin,
		}}
	>
		<slot name="banner" />
		{
			(site.creative?.cursor || site.creative?.trail || site.creative?.grain || site.creative?.clickMark) && (
				<CreativeEffects client:load creative={site.creative} />
			)
		}
		{
			showLogo && (
				<Logo
					client:load
					logo={logo}
					imageSrc={logoImageSrc}
					href={withBase(base)}
					automaticContrast={automaticContrast}
					fallbackBackground={pageBackground}
					stabilized={stabilized}
					position={theme.logoPosition}
					freeformX={theme.logoX}
					freeformY={theme.logoY}
				/>
			)
		}
		<div class={`portfolio-container nav-style-${navStyle} logo-position-${theme.logoPosition ?? 'center'}`}>
			<!-- The menu lives here permanently; hydrated for the hover-magnify. -->
			<nav class:list={{ sidebar: true, 'is-stabilized': stabilized }}>
				<Nav
					client:load
					items={nav}
					base={base}
					current={current}
					navStyle={navStyle}
					fullscreenMobile={theme.fullscreenMobileMenu}
					automaticContrast={automaticContrast}
					fallbackBackground={pageBackground}
					stabilized={stabilized}
				/>
			</nav>

			<!-- Each page injects its unique content here. -->
			<section class="content-view">
				<slot />
			</section>
		</div>
	</body>
</html>
